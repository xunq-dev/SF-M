{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synapse Framework",
  "version": "0.1.0",
  "identifier": "com.synapse.framework",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": ".."
    },
    "beforeBuildCommand": {
      "script": "npm run build:release",
      "cwd": ".."
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/32x32.png"
    ],
    "resources": [
      "resources/scripts",
      "resources/scripthub"
    ],
    "windows": {
      "wix": {
        "template": "wix/main.wxs"
      }
    }
  }
}